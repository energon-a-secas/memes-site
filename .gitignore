# ── macOS ─────────────────────────────────────────────────────────────────────
.DS_Store
.tool-versions

# ── Playwright MCP (Claude Code browser automation — screenshots, logs) ───────
.playwright-mcp/

# ── Node (local tooling only — these projects have no npm dependencies) ───────
node_modules/
npm-debug.log*

# ── Convex generated files (auto-created by `npx convex dev`) ────────────────
convex/_generated/

# ── Dev notes ─────────────────────────────────────────────────────────────────
example.txt

# ── Secrets — never commit ────────────────────────────────────────────────────
.env
.env.*

# ── Prevent deployment of dev files ──────────────────────────────────────────
package.json
.claudeignore

# ── Jekyll artifacts (legacy) ─────────────────────────────────────────────────
_site/
.jekyll-cache/
.sass-cache/
.jekyll-metadata
vendor/
.bundle/
