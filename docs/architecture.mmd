flowchart TB
    User([User]) --> HTML["index.html\nApp shell"]

    subgraph Frontend["Frontend (ES Modules)"]
        HTML --> app["app.js\nEntry point"]
        app --> state["state.js\nAuth + filter state"]
        app --> render["render.js\nMeme grid + cards"]
        app --> events["events.js\nUpload, vote, auth"]
        app --> data["data.js\nConvex client layer"]
        app --> utils["utils.js\nHelpers"]
    end

    subgraph Convex["Convex Backend"]
        data -->|"mutations / queries"| auth["auth.ts\nLogin / register"]
        data -->|"mutations / queries"| memes["memes.ts\nMeme CRUD + storage"]
        data -->|"mutations / queries"| votes["votes.ts\nUpvote / downvote"]
        auth & memes & votes --> DB[("Database\nusers / memes / votes")]
        memes --> FS[("File Storage")]
    end
